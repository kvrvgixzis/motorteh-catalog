---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allEntries = await getCollection('catalog');

const brands = allEntries
  .filter(e => !e.id.includes('/') || e.id.endsWith('/index'))
  .filter(e => !e.data.hidden)
  .sort((a, b) => a.data.sort - b.data.sort);
---

<BaseLayout title="Каталог — Мотор технология">
  <div class="breadcrumb">
    <a href={base}>Главная</a> <span>›</span> Каталог
  </div>

  <h1>Каталог оборудования</h1>

  <div class="brand-grid">
    {brands.map(brand => {
      const slug = brand.id.includes('/') ? brand.id.split('/')[0] : brand.id;
      return (
        <a href={`${base}catalog/${slug}/`} class="brand-card">
          {brand.data.icon && <img src={`${base}${brand.data.icon.replace(/^\//, '')}`} alt={brand.data.title} />}
          <span>{brand.data.title}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>
