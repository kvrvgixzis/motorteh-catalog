---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('catalog');

  const brandSlugs = new Set<string>();
  for (const entry of allEntries) {
    const parts = entry.id.split('/');
    brandSlugs.add(parts[0]);
  }

  const paths = [];
  for (const brandSlug of brandSlugs) {
    const brandEntry = allEntries.find(
      e => e.id === brandSlug || e.id === `${brandSlug}/index`
    );

    const children = allEntries.filter(
      e => e.id.startsWith(`${brandSlug}/`) && !e.id.endsWith('/index')
    );

    paths.push({
      params: { brand: brandSlug },
      props: { brandEntry, children },
    });
  }

  return paths;
}

const { brand } = Astro.params;
const { brandEntry, children } = Astro.props;

const sortedChildren = children
  .filter((c: any) => !c.data.hidden)
  .sort((a: any, b: any) => a.data.sort - b.data.sort);

let brandBody = '';
if (brandEntry?.body?.trim()) {
  brandBody = brandEntry.body;
}
---

<BaseLayout title={`${brandEntry?.data?.title || brand} — Мотор технология`}>
  <div class="breadcrumb">
    <a href="/">Главная</a> <span>›</span>
    <a href="/catalog/">Каталог</a> <span>›</span>
    {brandEntry?.data?.title || brand}
  </div>

  <h1>{brandEntry?.data?.title || brand}</h1>

  {sortedChildren.length > 0 ? (
    <div class="category-grid">
      {sortedChildren.map((child: any) => (
        <a href={`/catalog/${brand}/${child.id.split('/').pop()}/`} class="category-card">
          {child.data.icon && <img src={child.data.icon} alt={child.data.title} />}
          <span>{child.data.title}</span>
        </a>
      ))}
    </div>
  ) : brandBody ? (
    <div class="content-html" set:html={brandBody} />
  ) : (
    <p>Раздел в разработке</p>
  )}
</BaseLayout>
