---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const defaultDescription =
  'Продажа моечного оборудования. Компания Мотор технология, г. Нижний Новгород';
const { title, description = defaultDescription, image } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = import.meta.env.SITE || 'https://kvrvgixzis.github.io';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image ? new URL(`${base}${image.replace(/^\//, '')}`, siteUrl).href : undefined;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Мотор технология" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <header>
      <nav>
        <a href={base} class="logo">Мотор технология</a>
        <div class="nav-links">
          <a href={`${base}catalog/`}>Каталог</a>
          <a href={`${base}contacts/`}>Контакты</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-content">
        <div class="footer-col">
          <strong>Компания «Мотор технология»</strong><br />
          📍 г. Нижний Новгород, ул. Заовражная, д. 7
        </div>
        <div class="footer-col">
          📞 <a href="tel:+78314663284">+7 (831) 466-32-84</a><br />
          📞 <a href="tel:+78314139316">+7 (831) 413-93-16</a>
        </div>
        <div class="footer-col">
          ✉️ <a href="mailto:motorteh.port@yandex.ru">motorteh.port@yandex.ru</a>
        </div>
      </div>
      <div class="footer-author">
        <a href="https://github.com/kvrvgixzis" target="_blank" rel="noopener">@nktpfn</a>
      </div>
    </footer>
  </body>
</html>
